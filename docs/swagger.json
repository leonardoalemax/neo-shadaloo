                "fighter_id": {
                    "type": "string"
                },
                "platform_id": {
                    "type": "integer"
                },
                "platform_name": {
                    "type": "string"
                },
                "platform_tool_name": {
                    "type": "string"
                },
                "short_id": {
                    "type": "integer"
                }
            }
        },
        "battlelog.ProfileComment": {
            "type": "object",
            "properties": {
                "profile_tag_name": {
                    "type": "string"
                }
            }
        },
        "battlelog.Replay": {
            "type": "object",
            "properties": {
                "player1_info": {
                    "$ref": "#/definitions/battlelog.PlayerInfo"
                },
                "player2_info": {
                    "$ref": "#/definitions/battlelog.PlayerInfo"
                },
                "replay_battle_sub_type_name": {
                    "type": "string"
                },
                "replay_battle_type": {
                    "type": "integer"
                },
                "replay_battle_type_name": {
                    "type": "string"
                },
                "replay_id": {
                    "type": "string"
                },
                "uploaded_at": {
                    "type": "integer"
                },
                "views": {
                    "type": "integer"
                }
            }
        },
        "battlelog.ReplayPage": {
            "type": "object",
            "properties": {
                "page": {
                    "type": "integer"
                },
                "replays": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/battlelog.Replay"
                    }
                },
                "total": {
                    "type": "integer"
                },
                "total_pages": {
                    "type": "integer"
                }
            }
        },
        "battlelog.TitleData": {
            "type": "object",
            "properties": {
                "title_data_plate_name": {
                    "type": "string"
                },
                "title_data_val": {
                    "type": "string"
                }
            }
        },
        "battlelog.WinLossStat": {
            "type": "object",
            "properties": {
                "losses": {
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                },
                "win_pct": {
                    "type": "integer"
                },
                "wins": {
                    "type": "integer"
                }
            }
        }
    }
}